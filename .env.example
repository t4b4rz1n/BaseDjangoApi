# ==============================================================================
# Base Project — Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values as needed.
# The start.sh script will generate this file for you automatically.
# ==============================================================================

# --- Django Core ---
SECRET_KEY=django-insecure-CHANGE-ME-IN-PRODUCTION
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
ALLOWED_CORS=http://localhost:3000,http://127.0.0.1:3000

# --- Database ---
# Set USE_SQLITE=True for local development without PostgreSQL
USE_SQLITE=False
DB_NAME=base_project_db
DB_USER=base_project_user
DB_PASSWORD=strong_password_123
DB_HOST=db_postgres
DB_PORT=5432

# --- Superuser ---
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=adminpass123

# --- MinIO / S3 Storage ---
# Set USE_MINIO=False to use local file storage
USE_MINIO=True
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_password
AWS_STORAGE_BUCKET_NAME=base-project-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_MINAIO_ENDPOINT_URL=http://localhost:9000
AWS_S3_USE_SSL=False
AWS_QUERYSTRING_AUTH=True
AWS_S3_CUSTOM_DOMAIN=localhost:9000/base-project-media
AWS_S3_URL_PROTOCOL=http:
AWS_DEFAULT_ACL=private
AWS_S3_OBJECT_PARAMETERS={"CacheControl": "max-age=86400"}

# --- JWT ---
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# --- Payment Gateways ---
SANDBOX=True
NOWPAYMENTS_API_KEY=nowpayments-api-key
NOWPAYMENTS_SANDBOX_API_KEY=nowpayments-sandbox-api-key
ZARINPAL_MERCHANT_ID=zarinpal-merchant-id
CALLBACK_URL=https://example.com/payment/verify/
CANCEL_URL=https://example.com/payment/cancel/

# --- Misc ---
ENABLE_FIELD_FILTER_PAGINATION=False
